# ─────────────────────────────────────────────────────────────────────
# CareAX · 환경 변수 예시
# 이 파일을 복사해서 .env 로 저장하고, 실제 값으로 채워주세요.
# .env 는 .gitignore 에 포함되어 있어 절대 커밋되지 않습니다.
# ─────────────────────────────────────────────────────────────────────

# Neon PostgreSQL 연결 문자열
# Neon 대시보드 → 프로젝트 → Connection Details → Connection string 복사
DATABASE_URL=postgresql://neondb_owner:[YOUR_PASSWORD]@ep-billowing-boat-aozwh69o.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ─── 이메일 발송 (Gmail 앱 비밀번호 권장) ────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=careax.rana@gmail.com
SMTP_PASS=[YOUR_APP_PASSWORD]

# 문의 알림 수신 이메일
NOTIFY_EMAIL=careax.rana@gmail.com
